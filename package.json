{
  "name": "magi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:test": "NITRO_PRESET=node-server NODE_ENV=test pnpm build",
    "dev": "VITE_PLUGIN_PWA=true pnpm dev:no-pwa",
    "dev:no-pwa": "nuxt dev --port 5173",
    "dev:prepare": "nuxt prepare",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "generate": "nuxt generate",
    "knip:fix": "knip --fix",
    "lint": "pnpm oxlint && eslint --ignore-pattern AGENTS.md",
    "lint:fix": "pnpm oxlint --fix && eslint --ignore-pattern AGENTS.md --fix",
    "oxlint": "oxlint app server shared",
    "postinstall": "nuxt prepare",
    "preview": "pnpm run build && nuxt preview --port 5173",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "pnpm build:test && pnpm test:e2e:prebuilt",
    "test:e2e:prebuilt": "playwright test",
    "test:e2e:ui": "pnpm build:test && pnpm test:e2e:prebuilt --ui",
    "test:e2e:webserver": "NODE_ENV=test pnpm exec nuxt preview --port 5678",
    "test:nuxt": "vitest --project nuxt",
    "test:typecheck": "nuxt prepare && vue-tsc -b --noEmit",
    "test:unit": "vitest --project unit",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@jamii/vue-paginated-scroll": "^1.0.8",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.3.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.1",
    "@nuxtjs/i18n": "10.4.1",
    "@nuxtjs/seo": "5.3.2",
    "@peterbud/nuxt-query": "1.9.0",
    "@tanstack/query-persist-client-core": "5.101.2",
    "@tanstack/vue-hotkeys": "^0.10.0",
    "@tanstack/vue-query": "5.101.2",
    "@tanstack/vue-virtual": "^3.13.31",
    "@tiptap/extension-blockquote": "^3.27.3",
    "@tiptap/extension-bold": "^3.27.3",
    "@tiptap/extension-code": "^3.27.3",
    "@tiptap/extension-emoji": "^3.27.3",
    "@tiptap/extension-heading": "^3.27.3",
    "@tiptap/extension-italic": "^3.27.3",
    "@tiptap/extension-mention": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-strike": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "14.3.0",
    "dompurify": "3.4.7",
    "emojibase": "^17.0.0",
    "emojibase-data": "^17.0.0",
    "es-toolkit": "^1.49.0",
    "idb-keyval": "^6.3.0",
    "marked": "^18.0.6",
    "matrix-js-sdk": "^41.9.0",
    "mime": "^4.1.0",
    "motion-v": "^2.3.0",
    "nuxt": "4.5.0",
    "nuxt-security": "2.6.0",
    "nuxt-tiptap-editor": "3.4.0",
    "nuxt-twemoji": "4.0.4",
    "nuxt-vitalizer": "2.0.0",
    "quick-lru": "^7.3.0",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "temporal-polyfill": "^0.3.2",
    "tiptap-extension-code-block-shiki": "^1.2.0",
    "ufo": "^1.6.4",
    "unstorage": "^1.17.5",
    "valibot": "^1.4.2",
    "virtua": "^0.49.3",
    "vitest-localstorage-mock": "^0.1.2",
    "vue": "3.6.0-rc.1",
    "vue-router": "^5.1.0",
    "workbox-core": "7.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.3.0",
    "@e18e/eslint-plugin": "^0.5.1",
    "@faker-js/faker": "^10.5.0",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@regle/nuxt": "1.28.3",
    "@types/node": "^25.9.5",
    "@unocss/eslint-plugin": "^66.7.5",
    "@unocss/nuxt": "^66.7.5",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/language-core": "^3.3.7",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-oxlint": "^1.73.0",
    "happy-dom": "20.10.6",
    "knip": "^6.26.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.73.0",
    "pathe": "^2.0.3",
    "playwright-core": "^1.61.1",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "unocss-preset-animations": "^1.3.0",
    "vite": "^8.1.4",
    "vitest": "4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
