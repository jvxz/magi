{
  "name": "magi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:test": "NITRO_PRESET=node-server NODE_ENV=test pnpm build",
    "dev": "VITE_PLUGIN_PWA=true nuxt dev",
    "dev:no-pwa": "nuxt dev",
    "dev:prepare": "nuxt prepare",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "generate": "nuxt generate",
    "knip:fix": "knip --fix",
    "lint": "pnpm oxlint && eslint --ignore-pattern AGENTS.md",
    "lint:fix": "pnpm oxlint --fix && eslint --ignore-pattern AGENTS.md --fix",
    "oxlint": "oxlint app server shared",
    "postinstall": "nuxt prepare",
    "preview": "pnpm run build && nuxt preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "pnpm build:test && pnpm test:e2e:prebuilt",
    "test:e2e:prebuilt": "playwright test",
    "test:e2e:ui": "pnpm build:test && pnpm test:e2e:prebuilt --ui",
    "test:e2e:webserver": "NODE_ENV=test pnpm exec nuxt preview --port 5678",
    "test:nuxt": "vitest --project nuxt",
    "test:typecheck": "nuxt typecheck",
    "test:unit": "vitest --project unit",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.2",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/seo": "5.1.3",
    "@peterbud/nuxt-query": "1.8.0",
    "@tanstack/query-persist-client-core": "5.100.14",
    "@tanstack/vue-hotkeys": "^0.10.0",
    "@tanstack/vue-query": "5.100.14",
    "@tanstack/vue-virtual": "^3.13.26",
    "@tiptap/extension-blockquote": "^3.24.0",
    "@tiptap/extension-bold": "^3.24.0",
    "@tiptap/extension-code": "^3.24.0",
    "@tiptap/extension-emoji": "^3.24.0",
    "@tiptap/extension-heading": "^3.24.0",
    "@tiptap/extension-italic": "^3.24.0",
    "@tiptap/extension-mention": "^3.24.0",
    "@tiptap/extension-strike": "^3.24.0",
    "@tiptap/extension-underline": "^3.24.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/nuxt": "14.3.0",
    "dompurify": "^3.4.7",
    "emojibase": "^17.0.0",
    "emojibase-data": "^17.0.0",
    "es-toolkit": "^1.47.0",
    "idb-keyval": "^6.2.4",
    "marked": "^18.0.4",
    "matrix-js-sdk": "^41.6.0",
    "motion-v": "^2.2.1",
    "nuxt": "4.4.6",
    "nuxt-security": "2.6.0",
    "nuxt-tiptap-editor": "3.4.0",
    "nuxt-twemoji": "4.0.3",
    "nuxt-vitalizer": "2.0.0",
    "quick-lru": "^7.3.0",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "temporal-polyfill": "^0.3.2",
    "tiptap-extension-code-block-shiki": "^1.2.0",
    "ufo": "^1.6.4",
    "unstorage": "^1.17.5",
    "valibot": "^1.4.1",
    "virtua": "^0.49.1",
    "vitest-localstorage-mock": "^0.1.2",
    "vue-router": "^5.1.0",
    "workbox-core": "7.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.3.0",
    "@e18e/eslint-plugin": "^0.5.0",
    "@faker-js/faker": "^10.4.0",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@regle/nuxt": "1.26.1",
    "@types/node": "^25.9.1",
    "@unocss/eslint-plugin": "^66.7.0",
    "@unocss/nuxt": "^66.7.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/language-core": "^3.3.3",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-oxlint": "^1.67.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.15.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.67.0",
    "playwright-core": "^1.60.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "unocss-preset-animations": "^1.3.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
